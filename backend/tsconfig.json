{
    "compilerOptions": {
       "lib": [
          "es2020",
          "DOM"
       ],
       "target": "ES2020",
       "module": "commonjs",
       "moduleResolution": "node",
               "esModuleInterop": true,

       "outDir": "./build",
       "rootDir": "./",
       "emitDecoratorMetadata": true,
       "experimentalDecorators": true,
       "sourceMap": true,
    },
    "include": [
    "src/**/*",
    "src/types/**/*"
  ],
 }